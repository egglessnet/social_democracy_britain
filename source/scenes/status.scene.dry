title: Status
new-page: true
is-special: true
on-arrival: {!
if (Q.unemployed) {
    Q.unemployed_2 = Q.unemployed.toFixed(1);
}
if (Q.inflation) {
    Q.inflation_2 = Q.inflation.toFixed(1);
}
Q.economic_growth_2 = '0';
if (Q.economic_growth) {
    Q.economic_growth_2 = Q.economic_growth.toFixed(1);
}
!}

= Status

[+ month : month +] [+ year +]

Resources available: [+ resources +]

Labour position: [? if spd_toleration : toleration ?][? if spd_in_government : in government - ?][? if spd_toleration == 0 and spd_in_government == 0 and spd_caretaker == 0 : opposition ?][? if spd_caretaker : caretaker government ?]
[? if in_weimar_coalition and spd_in_government: Centre Coalition ?][? if in_grand_coalition and spd_in_government: National Coalition ?][? if in_popular_front and spd_in_government: Popular Front ?][? if in_left_front and spd_in_government: Left Front ?][? if in_spd_majority and spd_in_government: Labour majority ?][? if in_minority_government and spd_in_government: minority government ?][? if in_emergency_government and spd_in_government: emergency government ?]

[? if spd_in_government and not in_spd_majority and not in_left_front : Coalition dissent: [+ coalition_dissent : coalition_dissent +] ?]

[? if spd_in_government and (in_left_front or in_popular_front): Communist coalition dissent: [+ kpd_coalition_dissent : coalition_dissent +] ?]

Internal dissent: [+ dissent_percent : dissent +]

[? if communist_influence_seen : Communist influence: [+ kpd_influence : kpd_influence +] ?]

= Government

Monarch: [+ president +]

[? if president == "Marx" : Presidential Relations: [+ marx_relation : relationships +] ?]

Prime Minister: [+ chancellor +] ([+ chancellor_party +])

House of Commons composition:

# 1928: 30, 1930: 25, 1932: 22
Labour: [+ spd_r +]%
[? if sapd_formed == 1 : SAPD: [+ sapd_r +]% ?]
# 1928: 15, 1930: 15, 1932: 
Monter Raving Loony Party: [+ z_r +]%
# CPGB --> ? --> Greens
[+ commie_name +]: [+ kpd_r +]%
# Liberals --> Lib dem
[+ lib_name +]: [+ ddp_r +]%
# 1928: 14, 1930: 7
Conservative: [+ dnvp_r +]%
# 1928: 3, 1930: 18
[+ fasc_name +]: [+ nsdap_r +]%
# 1928: 9, 1930: 10
Other and Independents: [+ other_r +]%

[? if spd_in_government = 1 : Budget: [+ budget +] ?]

Next election: [+ next_election_month : month +] [+ next_election_year +]

= Economics

Inflation: [+ inflation_2 +]%

[? if black_thursday_seen = 1 : Unemployment: [+ unemployed_2 +]% ?]

Economic growth: [+ economic_growth_2 +]%


